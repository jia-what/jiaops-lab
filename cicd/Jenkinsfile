pipeline {
    agent any

    options {
        skipDefaultCheckout(true)
        timestamps()
        disableConcurrentBuilds()
    }

    triggers {
        githubPush()
    }

    environment {
        COMPOSE_FILE = '/opt/jiaops-compose/deploy/compose/docker-compose.yml'
        COMPOSE_ENV_FILE = '/opt/jiaops-compose/deploy/compose/.env'
        COMPOSE_PROFILES = 'with-redis'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_SHORT_SHA = sh(
                        script: 'git rev-parse --short=7 HEAD',
                        returnStdout: true
                    ).trim()
                    env.APP_TAG = "build-${env.BUILD_NUMBER}-${env.GIT_SHORT_SHA}"
                }
                echo "Deploying jiaops-app:${env.APP_TAG}"
            }
        }

        stage('Verify Docker access') {
            steps {
                sh '''
                    set -eu
                    test -S /var/run/docker.sock
                    test -f "$COMPOSE_ENV_FILE"
                    docker version --format '{{.Server.Version}}'
                    docker compose version
                '''
            }
        }

        stage('Build image') {
            steps {
                sh '''
                    set -eu
                    docker build \
                      --tag "jiaops-app:${APP_TAG}" \
                      --file app/Dockerfile \
                      app
                '''
            }
        }

        stage('Deploy Compose stack') {
            steps {
                sh '''
                    set -eu
                    APP_TAG="$APP_TAG" \
                    COMPOSE_PROFILES="$COMPOSE_PROFILES" \
                    docker compose \
                      --env-file "$COMPOSE_ENV_FILE" \
                      --file "$COMPOSE_FILE" \
                      up --detach --no-build --remove-orphans
                '''
            }
        }

        stage('Health check') {
            steps {
                sh '''
                    set -eu
                    for attempt in $(seq 1 12); do
                      if docker exec jiaops-nginx wget -qO- http://127.0.0.1/health \
                        | grep -Eq '"status"[[:space:]]*:[[:space:]]*"ok"'; then
                        echo "Health check passed."
                        exit 0
                      fi
                      echo "Health check attempt ${attempt}/12 failed; retrying in 5 seconds."
                      sleep 5
                    done

                    echo "Health check failed."
                    exit 1
                '''
            }
        }
    }

    post {
        always {
            sh '''
                docker ps --filter 'name=^/jiaops-' \
                  --format 'table {{.Names}}\t{{.Image}}\t{{.Status}}' || true
            '''
        }
        failure {
            sh '''
                docker logs --tail 100 jiaops-nginx || true
                docker logs --tail 100 jiaops-app || true
            '''
        }
    }
}
