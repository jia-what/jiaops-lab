# 复制为 .env 后使用（deploy/compose/.env 勿提交）
# cp .env.example .env

# MySQL（容器内；应用通过服务名 mysql 连接）
MYSQL_ROOT_PASSWORD=JiaopsRoot@123
MYSQL_DATABASE=jiaops
MYSQL_USER=jiaops
MYSQL_PASSWORD=Jiaops@123

# Flask（容器）
FLASK_DEBUG=0
MYSQL_HOST=mysql
MYSQL_PORT=3306

# 宿主机映射：裸机 MVP 占着 80 时，先用 8080 并行验证
NGINX_HOST_PORT=8080
